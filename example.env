# Grokmirror upstream source (where you mirror FROM)
MIRROR_UPSTREAM_HOST=https://lore.example.org
GROKMIRROR_MODE=clone
# or indexed

# Extindex: run cross-inbox search index after each pull cycle
# true = index repos AND update extindex (default)
# false = index repos only, skip extindex
GROKMIRROR_EXTINDEX_ENABLED=true

# public-inbox hosting congfigs
PI_NNTP_ENABLE=false
PI_HTTP_ENABLE=true
PI_INDEXING_ENABLE=false

# Indexing performance options
# Index level: basic (no full-text search), medium (no phrase search), full (default)
PI_INDEX_LEVEL=medium
# Fast indexing flags: --no-fsync --dangerous --batch-size --skip-docdata
# Speeds up indexing at cost of corruption risk on power loss and no concurrent readers
PI_INDEX_DANGEROUSLY_FAST=false

# IMAP watching for hosting your own lists (optional)
PI_IMAP_ENABLED=false
PI_IMAP_LIST_NAME=list.name
PI_IMAP_LIST_ADDRESS=name@lists.domain.tld
PI_IMAP_AUTH_URL=imaps://user:pass@imap.server.tld:993/INBOX
SPAMCHECK_ENABLED=false

# Public-inbox serving URL (where you serve TO)
SERVE_HOST=localhost
SERVE_HTTP_PORT=80
SERVE_HTTPS_PORT=443
SERVE_NNTP_PORT=119

# ACME/SSL configuration
ACME_ENABLED=false
ACME_EMAIL=admin@example.com


